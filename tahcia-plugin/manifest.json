{
  "manifest_version": 3,
  "name": "Tahcia Console",
  "version": "1.0.6",
  "description": "Connect browser tabs to Tahcia Console for remote control",
  "permissions": [
    "tabs",
    "storage",
    "scripting",
    "background",
    "unlimitedStorage",
    "clipboardRead",
    "clipboardWrite",
    "webNavigation",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "externally_connectable": {
    "matches": [
      "https://*.tahcia.com/console"
    ]
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+0",
        "mac": "MacCtrl+0"
      },
      "description": "Open popup"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.tahcia.com/console"
      ],
      "js": [
        "content/console-bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}